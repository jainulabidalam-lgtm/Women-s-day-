<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Women's Day</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Dancing+Script:wght@700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0010;
    overflow: hidden;
    width: 100vw;
    height: 100vh;
    font-family: 'Playfair Display', serif;
  }

  canvas {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .text-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
  }

  .happy {
    font-family: 'Dancing Script', cursive;
    font-size: clamp(2rem, 6vw, 5rem);
    color: #ffb6e1;
    text-shadow: 0 0 30px #ff69b4, 0 0 60px #ff1493;
    animation: pulse 2s ease-in-out infinite, fadeInDown 1.5s ease forwards;
    opacity: 0;
    letter-spacing: 4px;
  }

  .womens {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 10vw, 9rem);
    font-weight: 700;
    background: linear-gradient(135deg, #ff69b4, #fff, #c084fc, #ff69b4);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s ease infinite, fadeInUp 1.5s ease 0.5s forwards;
    opacity: 0;
    line-height: 1;
    letter-spacing: -2px;
    text-align: center;
  }

  .day {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 10vw, 9rem);
    font-weight: 700;
    background: linear-gradient(135deg, #c084fc, #ff69b4, #fff, #c084fc);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s ease 1s infinite, fadeInUp 1.5s ease 0.8s forwards;
    opacity: 0;
    line-height: 1;
    letter-spacing: -2px;
  }

  .tagline {
    font-family: 'Dancing Script', cursive;
    font-size: clamp(1rem, 2.5vw, 1.8rem);
    color: rgba(255, 182, 225, 0.85);
    margin-top: 1.5rem;
    letter-spacing: 6px;
    text-transform: uppercase;
    animation: fadeIn 2s ease 2s forwards;
    opacity: 0;
    text-shadow: 0 0 20px #ff69b4;
  }

  .date-badge {
    margin-top: 1rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(0.9rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 3px;
    animation: fadeIn 2s ease 2.5s forwards;
    opacity: 0;
  }

  @keyframes shimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes pulse {
    0%, 100% { text-shadow: 0 0 30px #ff69b4, 0 0 60px #ff1493; }
    50% { text-shadow: 0 0 50px #ff69b4, 0 0 100px #ff1493, 0 0 20px #fff; }
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
</head>
<body>
<canvas id="c"></canvas>

<div class="text-overlay">
  <div class="happy">Happy</div>
  <div class="womens">Women's</div>
  <div class="day">Day</div>
  <div class="tagline">✦ Strength · Grace · Power ✦</div>
  <div class="date-badge">March 8, 2026</div>
</div>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
let W, H;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ── Firework system ──────────────────────────────────────────
const COLORS = [
  '#ff69b4','#ff1493','#c084fc','#e879f9',
  '#f9a8d4','#ffffff','#fbbf24','#fb7185',
  '#a78bfa','#f472b6'
];

class Particle {
  constructor(x, y, color) {
    this.x = x; this.y = y;
    this.color = color;
    const angle = Math.random() * Math.PI * 2;
    const speed = Math.random() * 7 + 1;
    this.vx = Math.cos(angle) * speed;
    this.vy = Math.sin(angle) * speed;
    this.alpha = 1;
    this.decay = Math.random() * 0.015 + 0.01;
    this.radius = Math.random() * 3 + 1;
    this.gravity = 0.08;
    this.trail = [];
  }
  update() {
    this.trail.push({x: this.x, y: this.y, alpha: this.alpha});
    if (this.trail.length > 6) this.trail.shift();
    this.vx *= 0.98;
    this.vy *= 0.98;
    this.vy += this.gravity;
    this.x += this.vx;
    this.y += this.vy;
    this.alpha -= this.decay;
  }
  draw() {
    for (let i = 0; i < this.trail.length; i++) {
      const t = this.trail[i];
      ctx.beginPath();
      ctx.arc(t.x, t.y, this.radius * 0.6, 0, Math.PI * 2);
      ctx.fillStyle = this.color;
      ctx.globalAlpha = t.alpha * 0.3 * (i / this.trail.length);
      ctx.fill();
    }
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fillStyle = this.color;
    ctx.globalAlpha = this.alpha;
    ctx.shadowBlur = 8;
    ctx.shadowColor = this.color;
    ctx.fill();
    ctx.shadowBlur = 0;
  }
}

class Firework {
  constructor() { this.reset(); }
  reset() {
    this.x = Math.random() * W;
    this.y = H * (0.65 + Math.random() * 0.2);
    this.tx = Math.random() * W;
    this.ty = H * (0.05 + Math.random() * 0.45);
    const dx = this.tx - this.x, dy = this.ty - this.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    this.vx = (dx / dist) * 14;
    this.vy = (dy / dist) * 14;
    this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
    this.done = false;
    this.particles = [];
    this.trail = [];
  }
  update() {
    if (this.done) return;
    this.trail.push({x: this.x, y: this.y});
    if (this.trail.length > 12) this.trail.shift();
    this.x += this.vx; this.y += this.vy;
    const dx = this.tx - this.x, dy = this.ty - this.y;
    if (Math.sqrt(dx*dx + dy*dy) < 15) { this.explode(); return; }
    this.vy += 0.05;
  }
  explode() {
    this.done = true;
    const count = 100 + Math.floor(Math.random() * 60);
    for (let i = 0; i < count; i++) {
      this.particles.push(new Particle(this.x, this.y, this.color));
    }
    // heart burst for some fireworks
    if (Math.random() < 0.3) this.heartBurst();
  }
  heartBurst() {
    for (let t = 0; t < Math.PI * 2; t += 0.15) {
      const hx = 16 * Math.pow(Math.sin(t), 3);
      const hy = -(13 * Math.cos(t) - 5 * Math.cos(2*t) - 2 * Math.cos(3*t) - Math.cos(4*t));
      const p = new Particle(this.x, this.y, '#ff69b4');
      p.vx = hx * 0.4; p.vy = hy * 0.4;
      this.particles.push(p);
    }
  }
  draw() {
    if (!this.done) {
      for (let i = 0; i < this.trail.length; i++) {
        const t = this.trail[i];
        ctx.beginPath();
        ctx.arc(t.x, t.y, 3, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = (i / this.trail.length) * 0.8;
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }
    this.particles.forEach(p => { p.update(); p.draw(); });
    this.particles = this.particles.filter(p => p.alpha > 0.01);
  }
}

// ── Marching Girls ──────────────────────────────────────────
class Girl {
  constructor(x, delay) {
    this.x = x;
    this.baseY = H - 55;
    this.delay = delay;
    this.t = -delay;
    this.scale = 0.85 + Math.random() * 0.3;
    this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
    this.dressColor = ['#ff69b4','#c084fc','#e879f9','#fb7185','#f9a8d4'][Math.floor(Math.random()*5)];
    this.hairColor = ['#2d0a0a','#5c1a1a','#1a0a2e','#0a2e1a','#2e1a0a'][Math.floor(Math.random()*5)];
    this.speed = 1.2 + Math.random() * 0.5;
    this.active = false;
  }

  update() {
    this.t += 0.05;
    if (this.t > 0) { this.active = true; this.x += this.speed; }
  }

  draw() {
    if (!this.active) return;
    const t = this.t;
    const x = this.x, y = this.baseY;
    const s = this.scale;
    const bounce = Math.sin(t * 6) * 3 * s;
    const armSwing = Math.sin(t * 6) * 18;
    const legSwing = Math.sin(t * 6) * 20;

    ctx.save();
    ctx.globalAlpha = 1;
    ctx.translate(x, y + bounce);
    ctx.scale(s, s);

    // Shadow
    ctx.beginPath();
    ctx.ellipse(0, 8, 14, 4, 0, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(0,0,0,0.25)';
    ctx.fill();

    // Legs
    const legColors = ['#f9a8d4','#e9d5ff'];
    [[legSwing, -8],[- legSwing, 8]].forEach(([ang, ox], i) => {
      ctx.save();
      ctx.translate(ox, -10);
      ctx.rotate(ang * Math.PI/180);
      ctx.beginPath();
      ctx.roundRect(-4, 0, 8, 28, 4);
      ctx.fillStyle = legColors[i % 2];
      ctx.fill();
      // Shoe
      ctx.beginPath();
      ctx.ellipse(0, 30, 7, 4, 0, 0, Math.PI*2);
      ctx.fillStyle = this.dressColor;
      ctx.fill();
      ctx.restore();
    });

    // Dress / body
    ctx.beginPath();
    ctx.moveTo(-14, -10);
    ctx.lineTo(14, -10);
    ctx.lineTo(22, 5);
    ctx.lineTo(-22, 5);
    ctx.closePath();
    ctx.fillStyle = this.dressColor;
    ctx.fill();
    // dress shine
    ctx.beginPath();
    ctx.moveTo(-5, -10);
    ctx.lineTo(5, -10);
    ctx.lineTo(8, 5);
    ctx.lineTo(-8, 5);
    ctx.closePath();
    ctx.fillStyle = 'rgba(255,255,255,0.15)';
    ctx.fill();

    // Torso
    ctx.beginPath();
    ctx.roundRect(-10, -38, 20, 30, 6);
    ctx.fillStyle = this.dressColor;
    ctx.fill();
    // collar
    ctx.beginPath();
    ctx.arc(0, -38, 8, Math.PI, 0);
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fill();

    // Arms
    [[-1, armSwing],[ 1, -armSwing]].forEach(([side, ang]) => {
      ctx.save();
      ctx.translate(side * 10, -35);
      ctx.rotate(ang * Math.PI / 180);
      ctx.beginPath();
      ctx.roundRect(side < 0 ? -6 : 0, 0, 6, 22, 3);
      ctx.fillStyle = '#fbbf24';
      ctx.fill();
      // hand
      ctx.beginPath();
      ctx.arc(side < 0 ? -3 : 3, 24, 5, 0, Math.PI*2);
      ctx.fillStyle = '#fde68a';
      ctx.fill();
      ctx.restore();
    });

    // Neck
    ctx.beginPath();
    ctx.roundRect(-4, -44, 8, 10, 3);
    ctx.fillStyle = '#fde68a';
    ctx.fill();

    // Head
    ctx.beginPath();
    ctx.ellipse(0, -54, 14, 16, 0, 0, Math.PI*2);
    ctx.fillStyle = '#fde68a';
    ctx.fill();

    // Hair
    ctx.beginPath();
    ctx.ellipse(0, -62, 15, 10, 0, 0, Math.PI*2);
    ctx.fillStyle = this.hairColor;
    ctx.fill();
    ctx.beginPath();
    ctx.ellipse(-14, -54, 6, 12, -0.4, 0, Math.PI*2);
    ctx.fill();
    ctx.beginPath();
    ctx.ellipse(14, -54, 6, 12, 0.4, 0, Math.PI*2);
    ctx.fill();
    // Hair ribbon
    ctx.beginPath();
    ctx.arc(10, -68, 5, 0, Math.PI*2);
    ctx.fillStyle = this.dressColor;
    ctx.fill();

    // Eyes
    [[-5, 4]].forEach(([ox]) => {
      ctx.beginPath();
      ctx.ellipse(ox, -56, 3.5, 4, 0, 0, Math.PI*2);
      ctx.fillStyle = '#fff';
      ctx.fill();
      ctx.beginPath();
      ctx.ellipse(ox, -55, 2, 2.5, 0, 0, Math.PI*2);
      ctx.fillStyle = '#1a0a2e';
      ctx.fill();
    });
    ctx.beginPath();
    ctx.ellipse(5, -56, 3.5, 4, 0, 0, Math.PI*2);
    ctx.fillStyle = '#fff';
    ctx.fill();
    ctx.beginPath();
    ctx.ellipse(5, -55, 2, 2.5, 0, 0, Math.PI*2);
    ctx.fillStyle = '#1a0a2e';
    ctx.fill();

    // Smile
    ctx.beginPath();
    ctx.arc(0, -51, 5, 0.2, Math.PI - 0.2);
    ctx.strokeStyle = '#c2410c';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Sign / flag
    if (Math.floor(this.x / 60) % 3 === 0) {
      ctx.save();
      ctx.translate(14, -55);
      ctx.rotate(-0.1 + Math.sin(t*3) * 0.05);
      ctx.beginPath();
      ctx.rect(0, -30, 2, 30);
      ctx.fillStyle = '#fff';
      ctx.fill();
      ctx.beginPath();
      ctx.rect(2, -30, 28, 18);
      ctx.fillStyle = this.dressColor;
      ctx.fill();
      ctx.font = 'bold 6px sans-serif';
      ctx.fillStyle = '#fff';
      ctx.fillText('♀', 10, -17);
      ctx.restore();
    }

    ctx.restore();
  }
}

// ── Ground & Stars ──────────────────────────────────────────
const stars = Array.from({length: 120}, () => ({
  x: Math.random() * 2000, y: Math.random() * H * 0.7,
  r: Math.random() * 1.5 + 0.3,
  a: Math.random(), twinkle: Math.random() * Math.PI * 2
}));

// Setup fireworks & girls
const fireworks = [];
const girls = [];

function spawnFirework() {
  fireworks.push(new Firework());
}

let lastFW = 0;
function spawnGirls() {
  for (let i = 0; i < 14; i++) {
    girls.push(new Girl(-80 - i * 80, i * 18));
  }
}
spawnGirls();

// ── Main loop ──────────────────────────────────────────────
function loop(ts) {
  ctx.clearRect(0, 0, W, H);

  // Background gradient
  const bg = ctx.createLinearGradient(0, 0, 0, H);
  bg.addColorStop(0, '#04000f');
  bg.addColorStop(0.6, '#0d0025');
  bg.addColorStop(1, '#1a002e');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Stars
  stars.forEach(s => {
    s.twinkle += 0.02;
    ctx.beginPath();
    ctx.arc(s.x % W, s.y, s.r, 0, Math.PI*2);
    ctx.fillStyle = `rgba(255,255,255,${0.4 + Math.sin(s.twinkle) * 0.4})`;
    ctx.fill();
  });

  // Ground
  const grd = ctx.createLinearGradient(0, H - 60, 0, H);
  grd.addColorStop(0, '#2d0a4e');
  grd.addColorStop(1, '#1a0030');
  ctx.fillStyle = grd;
  ctx.fillRect(0, H - 60, W, 60);
  // ground shimmer
  ctx.beginPath();
  ctx.moveTo(0, H - 60);
  ctx.lineTo(W, H - 60);
  ctx.strokeStyle = 'rgba(255,105,180,0.4)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Fireworks
  if (ts - lastFW > 800) { spawnFirework(); lastFW = ts; }
  for (let i = fireworks.length - 1; i >= 0; i--) {
    fireworks[i].update();
    fireworks[i].draw();
    if (fireworks[i].done && fireworks[i].particles.length === 0) fireworks.splice(i, 1);
  }

  // Girls
  girls.forEach(g => { g.update(); g.draw(); });
  // Respawn girls that go off screen
  girls.forEach((g, i) => {
    if (g.x > W + 100) g.x = -80;
  });

  ctx.globalAlpha = 1;
  requestAnimationFrame(loop);
}

requestAnimationFrame(loop);
</script>
</body>
</html>
